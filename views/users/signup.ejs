<%layout("/layouts/boilerplate")%>

<div class="row mt-3">
  <h1 class="col-6 offset-3">Signup</h1>
<form id="signupForm" method="POST" action="/signup" novalidate class="needs-validation">

  <div class="row">
    <div class="col-md-6 offset-md-3">

      <!-- Username -->
      <div class="mb-3">
        <label for="username" class="form-label">Username</label>
        <input 
          name="username" 
          value="<%= userData?.username || '' %>"
          id="username"
          placeholder="Enter username" 
          type="text" 
          class="form-control" 
          required
        >
        <div class="invalid-feedback">Username is required</div>
      </div>

      

      <!-- Password -->
      <div class="mb-3">
        <label for="password" class="form-label">Password</label>
        <input 
          name="password" 
          value="<%= userData?.password || '' %>"
          id="password"
          placeholder="Create password" 
          type="password" 
          class="form-control" 
          required
        >
        <div class="invalid-feedback">Password is required</div>
      </div>
      <div class="mb-3">

        <div class="mb-3">
  <label for="phone" class="form-label">Phone Number</label>
  <input 
    id="phone"
    name="phone"
    placeholder="+91XXXXXXXXXX"
    type="text"
    class="form-control"
    required
  >
  <div class="invalid-feedback">Enter valid phone number</div>
</div>

<div class="mb-3">
  <button type="button" class="btn btn-outline-primary w-100" onclick="sendOTP()">
    Send Phone OTP
  </button>
</div>

<div class="mb-3">
  <input 
    type="text"
    id="phoneOtp"
    placeholder="Enter Phone OTP"
    class="form-control"
  >
</div>

<div class="mb-3">
  <button type="button" class="btn btn-outline-success w-100" onclick="verifyOTP()">
    Verify Phone
  </button>
</div>

<input type="hidden" name="phoneVerified" id="phoneVerified">
<div id="recaptcha-container"></div>


  <!-- Email -->
      <div class="mb-3">
        <label for="email" class="form-label">Email</label>
        <input 
          name="email" 
          value="<%= userData?.email || '' %>"
          id="email"
          placeholder="Enter email" 
          type="email" 
          class="form-control" 
          required
        >
        <div class="invalid-feedback">Please enter a valid email</div>
      </div>
  <% if (otpSent) { %>
    <label for="otp" class="form-label">OTP</label>
    <input 
      type="text" 
      name="otp" 
      id="otp"
      placeholder="Enter OTP" 
      class="form-control" 
      required
    >
    <div class="invalid-feedback">Please enter OTP</div>
  <% } %>
</div>
      

      <!-- Button -->
 <% if (otpSent) { %>
    <button class="btn btn-dark" type="submit">Verify & Signup</button>
  <% } else { %>
    <button class="btn btn-dark" type="submit">Send OTP for email </button>
  <% } %>
      <!-- Redirect -->
      <p class="mt-3 text-center">
        Already have an account? <a href="/login">Login</a>
      </p>

    </div>
  </div>

</form>
</div>


<script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-auth-compat.js"></script>

<script>
const firebaseConfig = {
  apiKey: "AIzaSyDW4S1KAjJSvLV2ApA3dzq269FKRquGqmI",
  authDomain: "rentease-ff3e7.firebaseapp.com",
  projectId: "rentease-ff3e7",
};

firebase.initializeApp(firebaseConfig);
const auth = firebase.auth();

window.recaptchaVerifier = new firebase.auth.RecaptchaVerifier('recaptcha-container', {
  size: "normal"
});

function sendOTP() {
  const phone = document.getElementById("phone").value;

  firebase.auth().signInWithPhoneNumber(phone, window.recaptchaVerifier)
    .then(function (confirmationResult) {
      window.confirmationResult = confirmationResult;
      alert("Phone OTP sent ");
    })
    .catch(function (error) {
      console.log(error);
      alert("Error sending OTP ");
    });
}

function verifyOTP() {
  const otp = document.getElementById("phoneOtp").value;

  window.confirmationResult.confirm(otp)
    .then(function () {
      alert("Phone Verified ");
      document.getElementById("phoneVerified").value = "true";
    })
    .catch(function () {
      alert("Invalid OTP ");
    });
}
</script>