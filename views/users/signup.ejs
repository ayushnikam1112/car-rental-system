<%layout("/layouts/boilerplate")%>

<div class="row mt-3">
  <h1 class="col-6 offset-3">Signup</h1>
<form id="signupForm" method="POST" action="/signup" novalidate class="needs-validation">

  <div class="row">
    <div class="col-md-6 offset-md-3">

      <!-- Username -->
      <div class="mb-3">
        <label for="username" class="form-label">Username</label>
        <input 
          name="username" 
          value="<%= userData?.username || '' %>"
          id="username"
          placeholder="Enter username" 
          type="text" 
          class="form-control" 
          required
        >
        <div class="invalid-feedback">Username is required</div>
      </div>

      

      <!-- Password -->
      <div class="mb-3">
        <label for="password" class="form-label">Password</label>
        <input 
          name="password" 
          value="<%= userData?.password || '' %>"
          id="password"
          placeholder="Create password" 
          type="password" 
          class="form-control" 
          required
        >
        <div class="invalid-feedback">Password is required</div>
      </div>
      <div class="mb-3">

  



  <!-- Email -->
      <div class="mb-3">
        <label for="email" class="form-label">Email</label>
        <input 
          name="email" 
          value="<%= userData?.email || '' %>"
          id="email"
          placeholder="Enter email" 
          type="email" 
          class="form-control" 
          required
        >
        <div class="invalid-feedback">Please enter a valid email</div>
      </div>
  <% if (otpSent) { %>
    <label for="otp" class="form-label">OTP</label>
    <input 
      type="text" 
      name="otp" 
      id="otp"
      placeholder="Enter OTP" 
      class="form-control" 
      required
    >
    <div class="invalid-feedback">Please enter OTP</div>
  <% } %>
</div>
      

      <!-- Button -->
 <% if (otpSent) { %>
    <button class="btn btn-dark" type="submit">Verify & Signup</button>
  <% } else { %>
    <button class="btn btn-dark" type="submit">Send OTP for email </button>
  <% } %>
      <!-- Redirect -->
      <p class="mt-3 text-center">
        Already have an account? <a href="/login">Login</a>
      </p>

    </div>
  </div>

</form>
</div>

