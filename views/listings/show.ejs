<% layout("/layouts/boilerplate") %>

<div class="container mt-5">

  <div class="row justify-content-center">
    <div class="col-lg-8">

      <!-- Card -->
      <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

        <!-- Image -->
        <img src="<%= listing.image.url %>" 
             class="card-img-top"
             style="height: 350px; object-fit: cover;">

        <!-- Body -->
        <div class="card-body p-4">

          <h3 class="fw mb-2"><%= listing.title %></h3>

          <p class="text-muted mb-2">
            <%= listing.location %>, <%= listing.country %>
          </p>

          <h5 class="fw-bold text-success mb-3">
            ₹ <%= listing.price.toLocaleString("en-IN") %> / day
          </h5>

          <p class="mb-4"><%= listing.description %></p>

          <!-- Unavailable Dates -->
          <div class="mb-4">
            <h5 class="fw-semibold">Unavailable Dates</h5>

            <% if (!bookings || bookings.length === 0) { %>
              <p class="text-muted">No bookings yet</p>
            <% } else { %>
              <div class="d-flex flex-wrap gap-2 mt-2">
                <% bookings.forEach(b => { %>
                  <span class="badge bg-danger px-3 py-2">
                    <%= new Date(b.fromDate).toLocaleDateString() %> -
                    <%= new Date(b.toDate).toLocaleDateString() %>
                  </span>
                <% }) %>
              </div>
            <% } %>
          </div>

          <!-- Book Button -->
          <% if(currUser && !currUser.isAdmin) { %>
            <a href="/bookings/new/<%= listing._id %>" 
               class="btn btn-success w-100 rounded-pill py-2">
              Book Now
            </a>
          <% } %>

          <!-- Admin Buttons -->
          <% if(currUser && currUser.isAdmin) { %>
            <div class="d-flex gap-2 mt-3">
              <a href="/listings/<%= listing._id %>/edit" 
                 class="btn btn-dark w-50">
                Edit
              </a>

              <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="w-50">
                <button class="btn btn-danger w-100">
                  Delete
                </button>
              </form>
            </div>
          <% } %>

        </div>
      </div>

      <!-- Review Section -->
      <div class="mt-5">

        <h4 class="fw-bold mb-3">Leave a Review</h4>

        <form action="/listings/<%= listing._id %>/reviews" method="POST" class="needs-validation" novalidate>
          
          <div class="mb-3">
            <label class="form-label">Rating</label>
            <input type="range" min="1" max="5" name="review[rating]" class="form-range">
          </div>

          <div class="mb-3">
            <label class="form-label">Comment</label>
            <textarea name="review[comment]" class="form-control" rows="4" required></textarea>
            <div class="invalid-feedback">Please add a review</div>
          </div>

          <button class="btn btn-dark">Submit</button>
        </form>

        <hr>

        <!-- Average Rating -->
        <%
          let total = 0;
          for(let r of listing.reviews){ total += r.rating; }
          let avg = listing.reviews.length ? (total / listing.reviews.length).toFixed(1) : 0;
        %>

        <h5 class="mb-3">⭐ <%= avg %> (<%= listing.reviews.length %> reviews)</h5>

        <!-- Reviews -->
        <div class="row">
          <% for(let review of listing.reviews){ %>

            <div class="col-md-6 mb-3">
              <div class="card shadow-sm border-0 rounded-3 h-100">

                <div class="card-body">

                  <h6 class="fw-bold mb-1">
                    @ <%= review.author ? review.author.username : "Anonymous" %>
                  </h6>

                  <p class="text-muted small mb-2">
                    <% for(let i=0;i<review.rating;i++){ %>⭐<% } %>
                  </p>

                  <p><%= review.comment %></p>

                  <% if(currUser && (currUser.isAdmin || (review.author && currUser._id.equals(review.author._id)))) { %>
                    <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                      <button class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                  <% } %>

                </div>
              </div>
            </div>

          <% } %>
        </div>

      </div>

    </div>
  </div>

</div>