<%layout("/layouts/boilerplate")%>

<div class="row">
    <div class="col-8 offset-3">
        <h3> Details </h3>
</div>
    <div class="card col-6 offset-3 show-card listing-card">
        <img src="<%=listing.image.url%>" class="card-img-top show-img" alt="listing_img">
  <div class="card-body">
    <p class="card-text">
        <b><%=listing.title%></b><br>
        <%=listing.description%><br>
        &#8377 <%=listing.price.toLocaleString("en-IN")%><br>
        <%=listing.location%><br>
        <%=listing.country %><br>
        </p>
  </div>
  <br>
     <% if(currUser&&!currUser.isAdmin) { %>
  <a href="/bookings/new/<%= listing._id %>" class="btn btn-success">
    Book Now 
  </a>
<% } %>
<hr>
    </div>
    <br>
   

    <% if(currUser && currUser.isAdmin) { %>
  <div class="btns">
    <a href="/listings/<%=listing._id%>/edit" class="btn btn-dark col-1 offset-3 add-btn">
      Edit
    </a>

    <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
      <button class="btn btn-dark offset-5">Delete</button>
    </form>
  </div>
<% } %>

    <div class="col-8 offset-3 mt-3"><br>
        <h4>Leave review</h4>
        <form action="/listings/<%=listing._id%>/reviews" method="POST" novalidate class="needs-validation">
            <div class="mb-3 mt-3">
                <label for="rating" class="form-label">
                    Rating
                </label>
                <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range">
            </div>
            <div>
                <label for="comment" class="form-label">Comment</label>
                <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control" required></textarea>
            <div class="invalid-feedback">Please add some review</div>
            </div><br>
            <button class="btn btn-dark">Submit</button>
        </form>

        <hr/>

        <p><b>All Reviews</b></p>
           <%
       let total = 0;
     for(let r of listing.reviews){
        total += r.rating;
          }
      let avg = listing.reviews.length ? (total / listing.reviews.length).toFixed(1) : 0;
        %>

      <h5>
       ⭐ <%= avg %> (<%= listing.reviews.length %> reviews)
      </h5> <br>
        <div class="row">
        <% for(let review of listing.reviews){%>
            <div class="card col-5 ms-3 mb-3" style="width: 18rem;">
  <div class="card-body">
 <h5>@ 
  <%= review.author ? review.author.username : "Anonymous" %>
</h5>
    <p class="card-text"><%=review.comment%></p>
   <p> <%for(let i=0;i<review.rating;i++){%>
        <span>⭐</span>
        <%}%>
   </p>
  <% if(currUser && (currUser.isAdmin || (review.author && currUser._id.equals(review.author._id)))) { %>
  <form method="POST" action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE">
    <button class="btn btn-sm btn-dark">Delete</button>
  </form>
<% } %>
  </div>
</div>
            <%}%>

    </div>

    </div>
    </div>

