<%layout("/layouts/boilerplate")%>

<form method="GET" action="/listings" class="row mb-4">

  <!-- Search -->
  <div class="col-md-3">
    <input type="text" name="search" class="form-control" placeholder="Search cars">
  </div>

  <!-- Location -->
  <div class="col-md-2">
    <input type="text" name="location" class="form-control" placeholder="Location">
  </div>

  <!-- Max Price -->
  <div class="col-md-2">
    <input type="number" name="price" class="form-control" placeholder="Max Price">
  </div>

  <!-- Button -->
  <div class="col-md-2">
    <button class="btn btn-dark w-100">Filter</button>
  </div>

</form>

<body>
    <h3>Available Cars</h3>
    <form method="GET" action="/listings/new">
       <!---- <button class="btn btn-dark add-btn">Create New Booking</button> -->
    </form>
    <br>
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
    <%for(let listing of allListings){%>
        <a href="/listings/<%=listing._id%>" class="listing-link">
    <div class="card col listing-card" >
  <img src="<%=listing.image.url%>" class="card-img-top" alt="listing_image" style="height: 20rem;">
  <div class="card-img-overlay">img</div>
  <div class="card-body">
    <p class="card-text">
        <b><%=listing.title%></b><br>
<%= listing.price ? "₹ " + listing.price.toLocaleString("en-IN") : "N/A" %>    </p>
    
  </div>
</div>
</a>
    <%}%>
    </div>
