<%layout("/layouts/boilerplate")%>

<!-- HERO SECTION -->
<section class="hero d-flex align-items-center text-white">
  <div class="container text-center">
    <h1 class="fw-bold">Rent Cars Easily </h1>
    <p>Affordable, reliable & comfortable rides anytime</p>

    <!-- SEARCH BAR -->
    <form class="d-flex justify-content-center mt-4" action="/listings">
      <input type="text" class="form-control w-50 me-2" placeholder="Search cars (SUV, Sedan...)">
      <button class="btn btn-warning">Search</button>
    </form>
  </div>
</section>

<!-- SERVICES -->
<section class="container py-5 text-center">
  <h2 class="mb-4">Our Services</h2>
  <div class="row">

    <div class="col-md-4">
      <div class="p-4 shadow rounded service-card">
        <i class="fa-solid fa-car-side fa-2x mb-3"></i>
        <h5>Self Drive Cars</h5>
        <p>Drive yourself with complete freedom</p>
      </div>
    </div>

    <div class="col-md-4">
      <div class="p-4 shadow rounded service-card">
        <i class="fa-solid fa-user-tie fa-2x mb-3"></i>
        <h5>Driver Service</h5>
        <p>Professional drivers for a smooth journey</p>
      </div>
    </div>

    <div class="col-md-4">
      <div class="p-4 shadow rounded service-card">
        <i class="fa-solid fa-route fa-2x mb-3"></i>
        <h5>Outstation Trips</h5>
        <p>Travel long distances with comfort</p>
      </div>
    </div>

  </div>
</section>

<!-- WHY US -->
<section class="bg-light py-5 text-center">
  <h2>Why Choose Us?</h2>
  <p>
    ✔ Well Maintained Cars <br>
    ✔ Affordable Pricing <br>
    ✔ 24/7 Customer Support <br>
    ✔ Easy Booking Process
  </p>
</section>

<!-- EXPERIENCE / TRUST SECTION -->
<section class="container py-5 text-center">
  <h2>Experience You Can Trust</h2>
  <p>
    With years of experience in car rentals, we ensure safe, reliable, and hassle-free journeys.
    Our customers trust us for quality service and comfort.
  </p>
</section>

<!-- TESTIMONIAL -->
<section class="bg-light py-5 text-center">
  <h2>What Our Customers Say</h2>
  <p>"Smooth booking and great cars! Highly recommended." ⭐⭐⭐⭐⭐</p>
</section>