<% layout("/layouts/boilerplate") %>

<h3 class="text-center mt-4">Admin Dashboard</h3>

<div class="container mt-4 d-flex gap-3 justify-content-center">

  <div class="card p-3 shadow">Total: <%= total %></div>
  <div class="card p-3 text-warning shadow">Pending: <%= pending %></div>
  <div class="card p-3 text-success shadow">Approved: <%= approved %></div>
  <div class="card p-3 text-danger shadow">Rejected: <%= rejected %></div>

</div>